generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// Enums
// =============================================================================

enum PriceSource {
  SELLER_LISTING
  COMPLETED_SALE
  EBAY_SOLD
  EBAY_LISTED
  COMMUNITY_POLL
  BUYLIST_OFFER
  MANUAL_REPORT
  AI_ESTIMATE
}

enum CardCondition {
  MINT
  NEAR_MINT
  LIGHTLY_PLAYED
  MODERATELY_PLAYED
  HEAVILY_PLAYED
  DAMAGED
}

enum ListingType {
  SINGLE
  BUNDLE
  MYSTERY_PACK
  SEALED_PRODUCT
}

enum ListingStatus {
  ACTIVE
  SOLD
  RESERVED
  RESERVED_FOR_PACK
  EXPIRED
  CANCELLED
}

enum OfferStatus {
  PENDING
  ACCEPTED
  DECLINED
  COUNTERED
  EXPIRED
  WITHDRAWN
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  SHIPPED
  DELIVERED
  COMPLETED
  DISPUTED
  REFUNDED
  CANCELLED
}

enum PollStatus {
  ACTIVE
  CLOSED
  EXPIRED
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum AlertType {
  PRICE_DROP
  PRICE_SPIKE
  BACK_IN_STOCK
  META_SHIFT
}

enum TradeStatus {
  PROPOSED
  ACCEPTED
  DECLINED
  WITHDRAWN
  COMPLETED
  CANCELLED
}

enum RevealPolicy {
  BUYER_CHOICE
  ALWAYS_REVEAL
  SELLER_REVEALS
}

// Bonus variants applied to a single physical card; the Dragon scoring engine
// adds a flat or treatment-keyed bonus on top of the base treatment points.
// Tokens are not in this enum — token-ness lives on the Card itself.
enum DragonScaleBonusVariant {
  NONE
  AUTOGRAPH
  ALT_ART
  ECHO
  PROMO
  ART_PROOF_DIGITAL
  PRE_RELEASE_FOIL
}

// PACK ownerType activates in Phase 2 with HuntingPack-pooled scoring.
enum DragonOwnerType {
  USER
  PACK
}

// Per-scale visibility for the public Stonefoil + OCM registry. Defaults
// to PRIVATE so opting in is explicit. PUBLIC_NAMED shows the owner's
// username; PUBLIC_ANONYMOUS shows "Anonymous Hunter" but still counts
// the slot as claimed.
enum RegistryVisibility {
  PRIVATE
  PUBLIC_NAMED
  PUBLIC_ANONYMOUS
}

// =============================================================================
// Dragon Cup Phase 2 — Hunting Packs + Contracts
// =============================================================================

enum HuntingPackStatus {
  ACTIVE
  DISBANDED
}

enum PackMemberRole {
  FOUNDER
  MEMBER
}

enum PackInvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  REVOKED
}

// Lifecycle:
//   DRAFT            → editing; no signatures collected yet
//   PENDING_APPROVAL → version published; collecting signatures from all parties
//   RATIFIED         → all required signatures collected; current version is in force
//   SUPERSEDED       → a newer version has been ratified
enum ContractStatus {
  DRAFT
  PENDING_APPROVAL
  RATIFIED
  SUPERSEDED
}

// Determines how prize money is split among pack members. MANUAL keeps the
// allocation as a free-form list inside bodyJson; PROPORTIONAL_BY_SCALES
// distributes by each member's contribution to the pack Dragon strength,
// after the rider payment has been deducted.
enum ContractPayoutMode {
  MANUAL
  PROPORTIONAL_BY_SCALES
}

enum RiderPaymentMode {
  FIXED_AMOUNT
  PERCENT
}

enum ContractSignatoryRole {
  PACK_MEMBER
  DRAGON_RIDER
}

// Append-only audit-log actions. Treat the enum as a soft contract — adding
// a value is fine; removing one would break historical reads.
enum ContractAuditAction {
  PACK_CREATED
  CONTRACT_DRAFTED
  VERSION_PROPOSED
  SIGNED
  DECLINED
  RATIFIED
  SUPERSEDED
  RIDER_APPOINTED
  RIDER_CHANGED
  MEMBER_JOINED
  MEMBER_LEFT
  INVITATION_SENT
  INVITATION_ACCEPTED
  INVITATION_DECLINED
}

// =============================================================================
// Dragon Cup Phase 3 — Tournament events
// =============================================================================

enum TournamentEventStatus {
  UPCOMING
  REGISTRATION_OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TournamentRegistrationStatus {
  REGISTERED
  CHECKED_IN
  WITHDRAWN
  DISQUALIFIED
  COMPLETED
}

// Side-category awards (PDF slide 16). TOP_DRAGON = single winner, most
// declared points entered. TOP_10 = top 10 by declared points. OSPREY =
// "Most Points Per Set" — top 3 by per-set scale-points contribution
// within each set the event covers.
enum TrialKind {
  TOP_DRAGON
  TOP_10
  OSPREY
}

// =============================================================================
// Game Registry
// =============================================================================

model Game {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  publisher   String
  website     String
  logoUrl     String?
  description String?
  createdAt   DateTime @default(now())

  sets  Set[]
  cards Card[]
}

model Set {
  id          String    @id @default(cuid())
  gameId      String
  game        Game      @relation(fields: [gameId], references: [id])
  name        String
  code        String
  releaseDate DateTime?
  totalCards  Int
  description String?

  cards Card[]

  @@unique([gameId, code])
}

// =============================================================================
// Cards
// =============================================================================

model Card {
  id     String @id @default(cuid())
  gameId String
  game   Game   @relation(fields: [gameId], references: [id])
  setId  String
  set    Set    @relation(fields: [setId], references: [id])

  // Identity
  cardNumber String
  name       String

  // WoTF-specific
  orbital String?

  // BOBA-specific
  athlete         String?
  teamAffiliation String?

  // Shared attributes
  rarity      String
  cardType    String
  treatment   String
  buildPoints Int?

  // Serialization
  isSerialized Boolean @default(false)
  serialTotal  Int?

  // Dragon Cup metadata. Stoneseekers and Lore Mythics earn 3x the base
  // treatment points (PDF slide 7 footnote). Tokens use a separate point
  // table and are not eligible for bonus variants.
  isStoneseeker Boolean @default(false)
  isLoreMythic  Boolean @default(false)
  isToken       Boolean @default(false)

  // Media
  imageUrl     String?
  imageUrlBack String?

  // Metadata
  flavorText String?
  rulesText  String?
  artist     String?

  // Generated tsvector column for full-text search; populated by Postgres
  // from name + cardNumber + rulesText + flavorText with weighted concat.
  // Read-only from Prisma's perspective; queried via raw SQL in src/lib/search.
  searchVector Unsupported("tsvector")?

  // Relations
  listings        Listing[]
  priceHistory    PriceDataPoint[]
  valuePollVotes  ValuePoll[]
  buylistEntries  BuylistEntry[]
  collectionCards CollectionCard[]
  saleReports     SaleReport[]
  marketValue     CardMarketValue?
  engineMetrics   CardEngineMetrics?
  engineHistory   CardEngineMetricsHistory[]
  alerts          UserAlert[]
  tradeItems      TradeItem[]
  dragonScales    DragonScale[]

  @@unique([setId, cardNumber, treatment])
  @@index([gameId, name])
  @@index([rarity])
  @@index([orbital])
}

// =============================================================================
// Price Discovery
// =============================================================================

model PriceDataPoint {
  id     String @id @default(cuid())
  cardId String
  card   Card   @relation(fields: [cardId], references: [id])

  source    PriceSource
  price     Decimal       @db.Decimal(10, 2)
  condition CardCondition
  treatment String

  // Source-specific references
  ebayListingId String?
  ebayItemUrl   String?
  listingId     String?
  pollId        String?
  reportedBy    String?

  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([cardId, createdAt])
  @@index([source])
}

model CardMarketValue {
  id     String @id @default(cuid())
  cardId String @unique
  card   Card   @relation(fields: [cardId], references: [id])

  // Composite values (NM default)
  marketLow  Decimal? @db.Decimal(10, 2)
  marketMid  Decimal? @db.Decimal(10, 2)
  marketHigh Decimal? @db.Decimal(10, 2)

  // Signal counts
  totalSales     Int @default(0)
  totalListings  Int @default(0)
  totalBuylist   Int @default(0)
  totalPollVotes Int @default(0)

  // Confidence (0-100)
  confidence Int @default(0)

  // Trends
  trend7d  Decimal? @db.Decimal(5, 2)
  trend30d Decimal? @db.Decimal(5, 2)

  // Volatility — absolute price stability over the last 30 days
  stdDev30d      Decimal? @db.Decimal(10, 2)
  coeffVar30d    Decimal? @db.Decimal(5, 4)
  volatilityTier String?

  // Scarcity — supply vs demand snapshot
  totalWanted    Int      @default(0)
  totalAvailable Int      @default(0)
  totalCollected Int      @default(0)
  scarcityRatio  Decimal? @db.Decimal(8, 4)
  scarcityTier   String?

  lastUpdated DateTime @default(now())

  @@index([confidence])
  @@index([volatilityTier])
  @@index([scarcityTier])
}

model CardEngineMetrics {
  id     String @id @default(cuid())
  cardId String @unique
  card   Card   @relation(fields: [cardId], references: [id])

  // Raw inputs cached from wonders-ccg-platform
  dbsScore            Int?
  deckInclusionPct    Decimal? @db.Decimal(5, 2)
  winRateWhenIncluded Decimal? @db.Decimal(5, 2)
  avgCopiesPlayed     Decimal? @db.Decimal(4, 2)
  replacementRate     Decimal? @db.Decimal(5, 2)

  // Computed PRI
  pri           Int?
  priConfidence Int?

  // Provenance
  format      String?
  windowStart DateTime?
  windowEnd   DateTime?

  lastSyncedAt DateTime @default(now())

  @@index([pri])
  @@index([deckInclusionPct])
}

// Per-sync snapshot of PRI. Lets the alert evaluator compare current PRI to
// a prior point in time (META_SHIFT detection). Append-only; no maintenance
// required beyond syncEngineMetrics writing one row per card per run.
model CardEngineMetricsHistory {
  id            String   @id @default(cuid())
  cardId        String
  card          Card     @relation(fields: [cardId], references: [id])
  pri           Int
  priConfidence Int?
  capturedAt    DateTime @default(now())

  @@index([cardId, capturedAt])
}

// =============================================================================
// Community Price Polls
// =============================================================================

model ValuePoll {
  id        String        @id @default(cuid())
  cardId    String
  card      Card          @relation(fields: [cardId], references: [id])
  treatment String
  condition CardCondition @default(NEAR_MINT)

  priceRanges Json
  status      PollStatus @default(ACTIVE)

  expiresAt DateTime
  createdAt DateTime @default(now())

  votes ValuePollVote[]
}

model ValuePollVote {
  id     String    @id @default(cuid())
  pollId String
  poll   ValuePoll @relation(fields: [pollId], references: [id])
  userId String
  user   User      @relation(fields: [userId], references: [id])

  selectedRange Int
  exactEstimate Decimal? @db.Decimal(10, 2)
  voterWeight   Float    @default(1.0)

  createdAt DateTime @default(now())

  @@unique([pollId, userId])
}

// =============================================================================
// Buylist
// =============================================================================

model Buylist {
  id       String  @id @default(cuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id])
  name     String
  isPublic Boolean @default(true)

  entries   BuylistEntry[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model BuylistEntry {
  id        String  @id @default(cuid())
  buylistId String
  buylist   Buylist @relation(fields: [buylistId], references: [id])
  cardId    String
  card      Card    @relation(fields: [cardId], references: [id])

  maxPrice  Decimal       @db.Decimal(10, 2)
  condition CardCondition @default(NEAR_MINT)
  treatment String
  quantity  Int           @default(1)

  autoNotify Boolean @default(true)

  // Bounty: same shape as a buylist entry, but with `isBounty=true` it's
  // surfaced publicly on the home page as "I want this card, will pay X".
  // bountyPostedAt is the sort key on the home rail (newest first).
  isBounty       Boolean   @default(false)
  bountyPostedAt DateTime?

  // When true, a matching listing (same card/treatment, condition >= bounty's,
  // price <= maxPrice) will trigger the auto-buy path. Stub today: logs +
  // notifies. Future: actually creates an Order on behalf of the bounty owner.
  autoBuy Boolean @default(false)

  @@unique([buylistId, cardId, treatment, condition])
  @@index([isBounty, bountyPostedAt])
  @@index([cardId, isBounty])
}

// =============================================================================
// Manual Sale Reports
// =============================================================================

model SaleReport {
  id         String @id @default(cuid())
  reporterId String
  reporter   User   @relation(fields: [reporterId], references: [id])
  cardId     String
  card       Card   @relation(fields: [cardId], references: [id])

  price     Decimal       @db.Decimal(10, 2)
  condition CardCondition
  treatment String
  platform  String

  proofUrl   String?
  verified   Boolean @default(false)
  verifiedBy String?

  saleDate  DateTime
  createdAt DateTime @default(now())
}

// =============================================================================
// Marketplace — Listings
// =============================================================================

model Listing {
  id       String @id @default(cuid())
  sellerId String
  seller   User   @relation("SellerListings", fields: [sellerId], references: [id])

  type   ListingType
  cardId String?
  card   Card?       @relation(fields: [cardId], references: [id])

  condition    CardCondition?
  treatment    String?
  serialNumber String?

  // Pricing
  price        Decimal  @db.Decimal(10, 2)
  currency     String   @default("USD")
  allowOffers  Boolean  @default(true)
  minimumOffer Decimal? @db.Decimal(10, 2)

  // Stock
  quantity     Int @default(1)
  quantitySold Int @default(0)

  // Media
  photos String[]

  // Shipping
  shipsFrom       String?
  shippingOptions Json?

  status ListingStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  offers      Offer[]
  orders      Order[]
  mysteryPack MysteryPack?

  @@index([cardId, status])
  @@index([sellerId])
  @@index([type])
}

// =============================================================================
// Mystery Packs
// =============================================================================

model MysteryPack {
  id        String  @id @default(cuid())
  listingId String  @unique
  listing   Listing @relation(fields: [listingId], references: [id])

  name        String
  description String

  guaranteedMinValue Decimal @db.Decimal(10, 2)
  cardCount          Int

  tiers        Json
  revealPolicy RevealPolicy @default(BUYER_CHOICE)

  outcomes MysteryPackOutcome[]
}

model MysteryPackOutcome {
  id            String      @id @default(cuid())
  mysteryPackId String
  mysteryPack   MysteryPack @relation(fields: [mysteryPackId], references: [id])
  orderId       String

  contents   Json
  totalValue Decimal @db.Decimal(10, 2)

  buyerRating  Int?
  buyerComment String?

  createdAt DateTime @default(now())
}

// =============================================================================
// Offers & Negotiation
// =============================================================================

model Offer {
  id        String  @id @default(cuid())
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id])
  buyerId   String
  buyer     User    @relation(fields: [buyerId], references: [id])

  amount  Decimal @db.Decimal(10, 2)
  message String?

  status OfferStatus @default(PENDING)

  parentOfferId String?
  parentOffer   Offer?  @relation("OfferChain", fields: [parentOfferId], references: [id])
  counterOffers Offer[] @relation("OfferChain")

  order Order?

  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  respondedAt DateTime?
}

// =============================================================================
// Orders & Transactions
// =============================================================================

model Order {
  id        String  @id @default(cuid())
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id])
  buyerId   String
  buyer     User    @relation("BuyerOrders", fields: [buyerId], references: [id])
  sellerId  String
  seller    User    @relation("SellerOrders", fields: [sellerId], references: [id])

  // Financials
  quantity    Int     @default(1)
  subtotal    Decimal @db.Decimal(10, 2)
  shipping    Decimal @db.Decimal(10, 2)
  platformFee Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)

  // Stripe
  stripeCheckoutSessionId String? @unique
  stripePaymentIntentId   String?
  stripeTransferId        String?

  // Origin offer when this order was created from an accepted offer
  acceptedOfferId String? @unique
  acceptedOffer   Offer?  @relation(fields: [acceptedOfferId], references: [id])

  // Shipping
  shippingMethod  String
  trackingNumber  String?
  shippingAddress Json

  status OrderStatus @default(PENDING_PAYMENT)

  paidAt      DateTime?
  shippedAt   DateTime?
  deliveredAt DateTime?
  completedAt DateTime?

  buyerRating  Int?
  sellerRating Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =============================================================================
// Collection Tracking
// =============================================================================

model Collection {
  id       String  @id @default(cuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id])
  name     String  @default("My Collection")
  isPublic Boolean @default(false)

  cards CollectionCard[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CollectionCard {
  id           String     @id @default(cuid())
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id])
  cardId       String
  card         Card       @relation(fields: [cardId], references: [id])

  quantity     Int           @default(1)
  condition    CardCondition @default(NEAR_MINT)
  treatment    String
  serialNumber String?

  acquiredPrice Decimal?  @db.Decimal(10, 2)
  acquiredDate  DateTime?
  acquiredFrom  String?

  forTrade    Boolean  @default(false)
  forSale     Boolean  @default(false)
  askingPrice Decimal? @db.Decimal(10, 2)

  notes String?

  dragonScales DragonScale[]

  @@unique([collectionId, cardId, treatment, condition, serialNumber])
}

// =============================================================================
// Users & Reputation
// =============================================================================

model User {
  id          String  @id @default(cuid())
  email       String  @unique
  username    String  @unique
  displayName String?
  avatarUrl   String?
  bio         String?

  country String?
  region  String?

  role UserRole @default(USER)

  sellerRating   Float?   @default(0)
  buyerRating    Float?   @default(0)
  totalSales     Int      @default(0)
  totalPurchases Int      @default(0)
  memberSince    DateTime @default(now())

  isVerified               Boolean @default(false)
  stripeAccountId          String?
  // Cached snapshot of charges_enabled && payouts_enabled, updated by the
  // account.updated webhook. Avoids a per-request Stripe roundtrip when
  // gating "can this seller list a card" or "can this buyer pay".
  stripeOnboardingComplete Boolean @default(false)
  cardeioPlayerId          String?

  credibilityScore Float @default(1.0)

  // Relations
  collections    Collection[]
  buylists       Buylist[]
  sellerListings Listing[]       @relation("SellerListings")
  buyerOrders    Order[]         @relation("BuyerOrders")
  sellerOrders   Order[]         @relation("SellerOrders")
  offers         Offer[]
  pollVotes      ValuePollVote[]
  saleReports    SaleReport[]
  alerts         UserAlert[]
  proposedTrades Trade[]         @relation("TradeProposer")
  receivedTrades Trade[]         @relation("TradeRecipient")
  dragonScales   DragonScale[]
  dragons        DragonRegistration[] @relation("UserDragons")
  ridingDragons  DragonRegistration[] @relation("DragonRider")

  packsFounded            HuntingPack[]        @relation("PackFounder")
  packMemberships         HuntingPackMember[]
  packInvitationsSent     PackInvitation[]     @relation("PackInvitationsSent")
  packInvitationsReceived PackInvitation[]     @relation("PackInvitationsReceived")
  contractsCreated        ContractVersion[]    @relation("ContractCreator")
  contractsAsRider        ContractVersion[]    @relation("ContractRider")
  contractSignatories     ContractSignatory[]
  contractAuditEntries    ContractAuditLog[]   @relation("ContractAuditActor")
  tournamentRegistrations TournamentRegistration[] @relation("RiderRegistrations")
}

// =============================================================================
// Alerts (PLANNING.md §9 — meta-shift / price-drop subscriptions)
// =============================================================================

model UserAlert {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  type   AlertType
  cardId String?
  card   Card?     @relation(fields: [cardId], references: [id])

  // For PRICE_DROP / PRICE_SPIKE: % change threshold that triggers the alert.
  // Null for BACK_IN_STOCK / META_SHIFT.
  thresholdPct Decimal? @db.Decimal(5, 2)

  active      Boolean   @default(true)
  lastFiredAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId, active])
  @@index([cardId, type])
}

// =============================================================================
// Trades (PLANNING.md §6 — card-for-card swaps)
// =============================================================================

model Trade {
  id          String @id @default(cuid())
  proposerId  String
  proposer    User   @relation("TradeProposer", fields: [proposerId], references: [id])
  recipientId String
  recipient   User   @relation("TradeRecipient", fields: [recipientId], references: [id])

  status TradeStatus @default(PROPOSED)

  // Optional cash equalizer paid by proposer to recipient (or negative for the
  // reverse direction). Null when the trade is a pure swap. Decimal(10,2) lets
  // the same money plumbing in checkout/webhook handle non-cash trades cleanly
  // when we later wire the payment leg.
  cashAdjustment Decimal? @db.Decimal(10, 2)

  message String?

  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  respondedAt DateTime?
  completedAt DateTime?

  items TradeItem[]

  @@index([proposerId])
  @@index([recipientId])
  @@index([status])
}

model TradeItem {
  id      String @id @default(cuid())
  tradeId String
  trade   Trade  @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  cardId  String
  card    Card   @relation(fields: [cardId], references: [id])

  // Which side this item belongs to. Trade items split into two groups by this
  // flag; both must net out to a fair (or cash-equalized) swap.
  fromProposer Boolean

  quantity  Int           @default(1)
  condition CardCondition @default(NEAR_MINT)
  treatment String

  @@index([tradeId])
}

// =============================================================================
// Dragon Cup — Phase 1: Dragon Scales + Dragon Stable
// =============================================================================
//
// A Dragon Scale is a per-instance ownership claim against a Card variant
// (treatment + optional bonus variant + optional serial). Scoring depends on
// the Card's rarity, its Dragon Cup metadata flags, the scale's treatment +
// bonusVariant + quantity, and the source Set's release recency. The scoring
// engine in src/lib/dragon/ is the source of truth; pointsCached is a write-
// through cache refreshed on every mutation. A Dragon (≥10,000 points) is
// surfaced via DragonRegistration. The PACK owner type is reserved for
// Phase 2 and not exercised by Phase 1 code paths.

model DragonScale {
  id               String   @id @default(cuid())
  userId           String
  cardId           String
  collectionCardId String?

  // Denormalised from Card.treatment so the cached score stays auditable
  // even if a future migration changes how treatments are represented.
  treatment    String
  bonusVariant DragonScaleBonusVariant @default(NONE)
  quantity     Int                     @default(1)
  serialNumber String?

  // Write-through cache; recalc is the source of truth.
  pointsCached       Int       @default(0)
  pointsCalculatedAt DateTime?

  // Public registry visibility. Drives the /registry page; Dragon Cup
  // scoring is unaffected (private scales still earn points for the
  // owner — only the outward display changes).
  visibility RegistryVisibility @default(PRIVATE)

  // Snapshot membership in any active TournamentBinderLock. A scale with
  // any LockedScale row whose binderLock.releasedAt is null cannot be
  // mutated until the lock releases. See src/lib/tournament/binder-lock.ts.
  lockedIn LockedScale[]

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  card           Card            @relation(fields: [cardId], references: [id], onDelete: Restrict)
  collectionCard CollectionCard? @relation(fields: [collectionCardId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, pointsCached])
  @@index([cardId])
}

model DragonRegistration {
  id          String          @id @default(cuid())
  ownerType   DragonOwnerType
  userOwnerId String?
  packOwnerId String?

  // Sum of contributing scale.pointsCached at lastRecalculatedAt.
  currentPoints      Int
  formedAt           DateTime  @default(now())
  dissolvedAt        DateTime?
  lastRecalculatedAt DateTime  @default(now())

  // Appointed Stoneseeker who will compete on behalf of this Dragon. May be
  // null until appointment; for pack Dragons, the rider must also be named
  // in the pack's ratified contract before tournament eligibility (Phase 3
  // enforces at registration time, not at appointment time).
  dragonRiderUserId String?
  dragonRider       User? @relation("DragonRider", fields: [dragonRiderUserId], references: [id], onDelete: SetNull)

  userOwner User?        @relation("UserDragons", fields: [userOwnerId], references: [id], onDelete: Cascade)
  packOwner HuntingPack? @relation("PackDragons", fields: [packOwnerId], references: [id], onDelete: Cascade)

  tournamentRegistrations TournamentRegistration[]

  // Postgres treats NULL as distinct in unique indexes pre-15, so the two
  // unique constraints are effectively partial: one enforces uniqueness for
  // USER rows, the other for PACK rows.
  @@unique([ownerType, userOwnerId])
  @@unique([ownerType, packOwnerId])
  @@index([currentPoints])
  @@index([dragonRiderUserId])
}

// =============================================================================
// Hunting Packs (Phase 2)
// =============================================================================

model HuntingPack {
  id        String            @id @default(cuid())
  name      String
  slug      String            @unique
  founderId String
  status    HuntingPackStatus @default(ACTIVE)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  founder       User                 @relation("PackFounder", fields: [founderId], references: [id])
  members       HuntingPackMember[]
  invitations   PackInvitation[]
  contract      PackContract?
  registrations DragonRegistration[] @relation("PackDragons")

  @@index([founderId])
  @@index([status])
}

// One row per (user × join event). Soft-deleted by setting leftAt — the row
// is preserved for audit so a member's earlier scale contributions can still
// be reasoned about when reading old contracts.
model HuntingPackMember {
  id       String         @id @default(cuid())
  packId   String
  userId   String
  role     PackMemberRole @default(MEMBER)
  joinedAt DateTime       @default(now())
  leftAt   DateTime?

  pack HuntingPack @relation(fields: [packId], references: [id], onDelete: Cascade)
  user User        @relation(fields: [userId], references: [id])

  @@index([packId, leftAt])
  @@index([userId, leftAt])
}

// Token-based invitation. inviteeEmail is required; inviteeUserId is set
// when we can resolve the email to an existing User at create time so that
// the invitee can see the invitation in their dashboard without clicking a
// link from an email. Both routes (token URL, dashboard panel) end up at
// the same accept/decline endpoints.
model PackInvitation {
  id             String               @id @default(cuid())
  packId         String
  inviterUserId  String
  inviteeEmail   String
  inviteeUserId  String?
  token          String               @unique
  status         PackInvitationStatus @default(PENDING)
  expiresAt      DateTime
  createdAt      DateTime             @default(now())
  respondedAt    DateTime?

  pack    HuntingPack @relation(fields: [packId], references: [id], onDelete: Cascade)
  inviter User        @relation("PackInvitationsSent", fields: [inviterUserId], references: [id])
  invitee User?       @relation("PackInvitationsReceived", fields: [inviteeUserId], references: [id])

  @@index([packId, status])
  @@index([inviteeEmail, status])
  @@index([inviteeUserId, status])
}

// =============================================================================
// Pack Contracts (Phase 2)
// =============================================================================
//
// A PackContract is a 1-1 with HuntingPack. Versions are immutable — every
// edit creates a new ContractVersion and reopens signature collection. The
// canonical body lives in bodyJson; bodyHash (SHA-256 of canonicalised JSON)
// is what each ContractSignature records, so any post-signature edit is
// detectable. The contract's `currentVersionId` always points at the most
// recent version (regardless of ratification state); the previously
// ratified version is identifiable via its non-null ratifiedAt.

model PackContract {
  id               String         @id @default(cuid())
  packId           String         @unique
  status           ContractStatus @default(DRAFT)
  currentVersionId String?        @unique
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  pack           HuntingPack       @relation(fields: [packId], references: [id], onDelete: Cascade)
  currentVersion ContractVersion?  @relation("CurrentVersion", fields: [currentVersionId], references: [id])
  versions       ContractVersion[] @relation("AllVersions")
  auditLog       ContractAuditLog[]
}

model ContractVersion {
  id                String             @id @default(cuid())
  contractId        String
  versionNumber     Int
  bodyJson          Json
  bodyHash          String
  payoutMode        ContractPayoutMode
  riderPaymentMode  RiderPaymentMode
  riderPaymentValue Decimal            @db.Decimal(12, 2)
  dragonRiderUserId String?
  createdByUserId   String
  createdAt         DateTime           @default(now())
  ratifiedAt        DateTime?

  contract           PackContract        @relation("AllVersions", fields: [contractId], references: [id], onDelete: Cascade)
  currentForContract PackContract?       @relation("CurrentVersion")
  dragonRider        User?               @relation("ContractRider", fields: [dragonRiderUserId], references: [id])
  createdBy          User                @relation("ContractCreator", fields: [createdByUserId], references: [id])
  signatories        ContractSignatory[]
  signatures         ContractSignature[]
  auditLog           ContractAuditLog[]

  @@unique([contractId, versionNumber])
}

// Named parties on a specific version. A user may appear twice when they
// hold two roles (e.g. both PACK_MEMBER and DRAGON_RIDER); each row needs
// its own signature. requiredForRatification is always true today but kept
// as a flag so future versions can model observers / cosigners.
model ContractSignatory {
  id                      String                @id @default(cuid())
  versionId               String
  userId                  String
  role                    ContractSignatoryRole
  requiredForRatification Boolean               @default(true)

  version   ContractVersion    @relation(fields: [versionId], references: [id], onDelete: Cascade)
  user      User               @relation(fields: [userId], references: [id])
  signature ContractSignature?

  @@unique([versionId, userId, role])
}

model ContractSignature {
  id             String   @id @default(cuid())
  versionId      String
  signatoryId    String   @unique
  signedAt       DateTime @default(now())
  signedBodyHash String
  ipAddress      String?
  userAgent      String?

  version   ContractVersion   @relation(fields: [versionId], references: [id], onDelete: Cascade)
  signatory ContractSignatory @relation(fields: [signatoryId], references: [id])
}

model ContractAuditLog {
  id          String              @id @default(cuid())
  contractId  String
  versionId   String?
  actorUserId String?
  action      ContractAuditAction
  payloadJson Json?
  createdAt   DateTime            @default(now())

  contract PackContract     @relation(fields: [contractId], references: [id], onDelete: Cascade)
  version  ContractVersion? @relation(fields: [versionId], references: [id], onDelete: SetNull)
  actor    User?            @relation("ContractAuditActor", fields: [actorUserId], references: [id])

  @@index([contractId, createdAt])
}

// =============================================================================
// Tournament Events (Phase 3)
// =============================================================================
//
// A TournamentEvent splits its prize money into two pools per the PDF:
// basePrizePool pays the Top 16 finishers regardless of collection size;
// dragonGoldPool pays the Top 32 by Weighted Points = declared × finish
// multiplier. Results land via admin endpoint after the event; the payout
// engine in src/lib/tournament/payout.ts is the single source of truth.

model TournamentEvent {
  id             String                @id @default(cuid())
  name           String
  slug           String                @unique
  description    String?
  eventDate      DateTime
  basePrizePool  Decimal               @default(0) @db.Decimal(12, 2)
  dragonGoldPool Decimal               @default(0) @db.Decimal(12, 2)
  status         TournamentEventStatus @default(UPCOMING)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  registrations TournamentRegistration[]
  trialAwards   TrialAward[]

  @@index([eventDate])
  @@index([status])
}

// One row per (event × dragon). Captures which rider is competing on
// behalf of the dragon (the PDF rule "a Stoneseeker can only ride one
// Dragon" is enforced per-event by the @@unique on (eventId, riderId)).
// declaredPoints is the hunter-declared snapshot — may be lower than actual
// to give a safety margin against accidental over-declaration; payouts use
// the declared value.
model TournamentRegistration {
  id                   String                       @id @default(cuid())
  eventId              String
  dragonRegistrationId String
  dragonRiderUserId    String
  declaredPoints       Int
  status               TournamentRegistrationStatus @default(REGISTERED)
  createdAt            DateTime                     @default(now())
  withdrawnAt          DateTime?

  event       TournamentEvent    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  dragon      DragonRegistration @relation(fields: [dragonRegistrationId], references: [id], onDelete: Restrict)
  rider       User               @relation("RiderRegistrations", fields: [dragonRiderUserId], references: [id])
  result      TournamentResult?
  trialAwards TrialAward[]
  binderLock  TournamentBinderLock?

  @@unique([eventId, dragonRegistrationId])
  @@unique([eventId, dragonRiderUserId])
  @@index([eventId, status])
  @@index([dragonRiderUserId])
}

// One result row per finishing dragon. multiplier + weighted + payouts are
// cached snapshots of what the payout engine produced — re-deriving on read
// would be wasted work, and keeping them recorded matters for audit (the
// hunter sees the math that produced their payout).
model TournamentResult {
  id                    String    @id @default(cuid())
  registrationId        String    @unique
  finishingPosition     Int
  multiplier            Decimal   @db.Decimal(6, 2)
  weightedPoints        Int
  basePayoutCents       Int       @default(0)
  dragonGoldPayoutCents Int       @default(0)
  paidOutAt             DateTime?
  createdAt             DateTime  @default(now())

  registration TournamentRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([finishingPosition])
}

// One row per side-category award. setCode is non-null only for OSPREY
// awards (Top 3 by per-set scale-points contribution). rank is 1..N
// within the (eventId, kind, setCode) bucket; uniqueness on the rank
// keeps re-computation idempotent.
model TrialAward {
  id             String    @id @default(cuid())
  eventId        String
  registrationId String
  kind           TrialKind
  setCode        String?
  rank           Int
  points         Int
  createdAt      DateTime  @default(now())

  event        TournamentEvent        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registration TournamentRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@unique([eventId, kind, setCode, rank])
  @@index([eventId, kind])
}

// =============================================================================
// Binder check-in / locking (PDF slides 9 + 13)
// =============================================================================
//
// At tournament registration, the contributing user's (or pack members')
// scales are snapshotted into a TournamentBinderLock. Each LockedScale
// records which DragonScale row was locked and the points it carried at
// the moment of lock — useful for the post-event audit (PDF: declared ≤
// actual). While the lock is active (releasedAt = null), the locked scale
// rows cannot be edited or deleted; new scales added to the binder after
// lock are unaffected. The lock auto-releases when the event status
// transitions to COMPLETED or CANCELLED.

model TournamentBinderLock {
  id                       String    @id @default(cuid())
  tournamentRegistrationId String    @unique
  lockedAt                 DateTime  @default(now())
  releasedAt               DateTime?
  declaredPointsAtLock     Int
  totalPointsAtLock        Int

  registration TournamentRegistration @relation(fields: [tournamentRegistrationId], references: [id], onDelete: Cascade)
  lockedScales LockedScale[]

  @@index([releasedAt])
}

model LockedScale {
  id            String @id @default(cuid())
  binderLockId  String
  dragonScaleId String
  pointsAtLock  Int

  binderLock  TournamentBinderLock @relation(fields: [binderLockId], references: [id], onDelete: Cascade)
  dragonScale DragonScale          @relation(fields: [dragonScaleId], references: [id], onDelete: Cascade)

  @@unique([binderLockId, dragonScaleId])
  @@index([dragonScaleId]) // hot path: "is this scale locked?"
}
