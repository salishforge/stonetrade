# Brand identity — same codebase deploys under different brands. Empty values
# fall back to StoneTrade-native defaults from src/lib/brand.ts.
NEXT_PUBLIC_BRAND_NAME=
NEXT_PUBLIC_BRAND_TAGLINE=
NEXT_PUBLIC_BRAND_LOGO=
NEXT_PUBLIC_BRAND_POWERED_BY=
NEXT_PUBLIC_BRAND_LEGAL_ENTITY=

# Auth mode: "mock" (default) returns a hardcoded dev-user; "supabase" uses real Supabase auth.
# When set to "supabase", NEXT_PUBLIC_SUPABASE_URL and NEXT_PUBLIC_SUPABASE_ANON_KEY must be set
# and the (auth)/login and (auth)/register pages must be implemented for end-to-end sign-in.
AUTH_MODE=mock

# CRON_TOKEN for unauthenticated cron-style admin endpoints. Set as a GitHub
# Actions secret (STONETRADE_CRON_TOKEN) and on the deployed server's env.
CRON_TOKEN=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=

# Anthropic (AI features)
ANTHROPIC_API_KEY=

# eBay
# App keyset from https://developer.ebay.com/my/keys
# EBAY_APP_ID is the Client ID, EBAY_CERT_ID is the Client Secret.
# EBAY_DEV_ID is required for Trading API calls (not used yet).
# EBAY_ENV: "production" (default) or "sandbox"
# EBAY_MARKETPLACE_ID: e.g. "EBAY_US", "EBAY_GB", "EBAY_DE"
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
EBAY_ENV=production
EBAY_MARKETPLACE_ID=EBAY_US

# Resend (email)
RESEND_API_KEY=
RESEND_FROM_ADDRESS=

# Novu (notifications — email/in-app/SMS/push fan-out)
# Get keys at https://web.novu.co. NOVU_API_KEY is the server-side secret used
# by src/lib/notify/novu.ts. NEXT_PUBLIC_NOVU_APP_IDENTIFIER is the public
# application identifier consumed by <NotificationBell> / @novu/react <Inbox>.
# Both are unset in dev → wrapper no-ops and the bell renders nothing.
NOVU_API_KEY=
NEXT_PUBLIC_NOVU_APP_IDENTIFIER=

# Carde.io (when partnership established)
CARDEIO_API_KEY=
CARDEIO_API_BASE_URL=

# Wonders CCG Platform (sibling project)
WONDERS_PLATFORM_API_URL=http://localhost:8001
# Where card images are served from. Local dev: the platform frontend serves
# /cards/{filename}.webp from frontend/public/cards/. Prod: a CDN or S3 mirror.
WONDERS_PLATFORM_IMAGE_BASE_URL=http://localhost:3000/cards

# Database (local dev — Supabase connection string in production)
DATABASE_URL=postgresql://stonetrade:stonetrade@localhost:5436/stonetrade

# Test database (used by `npm test`; tests/setup.ts swaps this in for DATABASE_URL when present)
TEST_DATABASE_URL=postgresql://stonetrade:stonetrade@localhost:5436/stonetrade_test
