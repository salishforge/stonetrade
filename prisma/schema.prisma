generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// Enums
// =============================================================================

enum PriceSource {
  SELLER_LISTING
  COMPLETED_SALE
  EBAY_SOLD
  EBAY_LISTED
  COMMUNITY_POLL
  BUYLIST_OFFER
  MANUAL_REPORT
  AI_ESTIMATE
}

enum CardCondition {
  MINT
  NEAR_MINT
  LIGHTLY_PLAYED
  MODERATELY_PLAYED
  HEAVILY_PLAYED
  DAMAGED
}

enum ListingType {
  SINGLE
  BUNDLE
  MYSTERY_PACK
  SEALED_PRODUCT
}

enum ListingStatus {
  ACTIVE
  SOLD
  RESERVED
  EXPIRED
  CANCELLED
}

enum OfferStatus {
  PENDING
  ACCEPTED
  DECLINED
  COUNTERED
  EXPIRED
  WITHDRAWN
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  SHIPPED
  DELIVERED
  COMPLETED
  DISPUTED
  REFUNDED
  CANCELLED
}

enum PollStatus {
  ACTIVE
  CLOSED
  EXPIRED
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum AlertType {
  PRICE_DROP
  PRICE_SPIKE
  BACK_IN_STOCK
  META_SHIFT
}

enum TradeStatus {
  PROPOSED
  ACCEPTED
  DECLINED
  WITHDRAWN
  COMPLETED
  CANCELLED
}

enum RevealPolicy {
  BUYER_CHOICE
  ALWAYS_REVEAL
  SELLER_REVEALS
}

// =============================================================================
// Game Registry
// =============================================================================

model Game {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  publisher   String
  website     String
  logoUrl     String?
  description String?
  createdAt   DateTime @default(now())

  sets  Set[]
  cards Card[]
}

model Set {
  id          String    @id @default(cuid())
  gameId      String
  game        Game      @relation(fields: [gameId], references: [id])
  name        String
  code        String
  releaseDate DateTime?
  totalCards  Int
  description String?

  cards Card[]

  @@unique([gameId, code])
}

// =============================================================================
// Cards
// =============================================================================

model Card {
  id     String @id @default(cuid())
  gameId String
  game   Game   @relation(fields: [gameId], references: [id])
  setId  String
  set    Set    @relation(fields: [setId], references: [id])

  // Identity
  cardNumber String
  name       String

  // WoTF-specific
  orbital String?

  // BOBA-specific
  athlete         String?
  teamAffiliation String?

  // Shared attributes
  rarity      String
  cardType    String
  treatment   String
  buildPoints Int?

  // Serialization
  isSerialized Boolean @default(false)
  serialTotal  Int?

  // Media
  imageUrl     String?
  imageUrlBack String?

  // Metadata
  flavorText String?
  rulesText  String?
  artist     String?

  // Generated tsvector column for full-text search; populated by Postgres
  // from name + cardNumber + rulesText + flavorText with weighted concat.
  // Read-only from Prisma's perspective; queried via raw SQL in src/lib/search.
  searchVector Unsupported("tsvector")?

  // Relations
  listings        Listing[]
  priceHistory    PriceDataPoint[]
  valuePollVotes  ValuePoll[]
  buylistEntries  BuylistEntry[]
  collectionCards CollectionCard[]
  saleReports     SaleReport[]
  marketValue     CardMarketValue?
  engineMetrics   CardEngineMetrics?
  engineHistory   CardEngineMetricsHistory[]
  alerts          UserAlert[]
  tradeItems      TradeItem[]

  @@unique([setId, cardNumber, treatment])
  @@index([gameId, name])
  @@index([rarity])
  @@index([orbital])
}

// =============================================================================
// Price Discovery
// =============================================================================

model PriceDataPoint {
  id     String @id @default(cuid())
  cardId String
  card   Card   @relation(fields: [cardId], references: [id])

  source    PriceSource
  price     Decimal       @db.Decimal(10, 2)
  condition CardCondition
  treatment String

  // Source-specific references
  ebayListingId String?
  listingId     String?
  pollId        String?
  reportedBy    String?

  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([cardId, createdAt])
  @@index([source])
}

model CardMarketValue {
  id     String @id @default(cuid())
  cardId String @unique
  card   Card   @relation(fields: [cardId], references: [id])

  // Composite values (NM default)
  marketLow  Decimal? @db.Decimal(10, 2)
  marketMid  Decimal? @db.Decimal(10, 2)
  marketHigh Decimal? @db.Decimal(10, 2)

  // Signal counts
  totalSales     Int @default(0)
  totalListings  Int @default(0)
  totalBuylist   Int @default(0)
  totalPollVotes Int @default(0)

  // Confidence (0-100)
  confidence Int @default(0)

  // Trends
  trend7d  Decimal? @db.Decimal(5, 2)
  trend30d Decimal? @db.Decimal(5, 2)

  // Volatility — absolute price stability over the last 30 days
  stdDev30d      Decimal? @db.Decimal(10, 2)
  coeffVar30d    Decimal? @db.Decimal(5, 4)
  volatilityTier String?

  // Scarcity — supply vs demand snapshot
  totalWanted    Int      @default(0)
  totalAvailable Int      @default(0)
  totalCollected Int      @default(0)
  scarcityRatio  Decimal? @db.Decimal(8, 4)
  scarcityTier   String?

  lastUpdated DateTime @default(now())

  @@index([confidence])
  @@index([volatilityTier])
  @@index([scarcityTier])
}

model CardEngineMetrics {
  id     String @id @default(cuid())
  cardId String @unique
  card   Card   @relation(fields: [cardId], references: [id])

  // Raw inputs cached from wonders-ccg-platform
  dbsScore            Int?
  deckInclusionPct    Decimal? @db.Decimal(5, 2)
  winRateWhenIncluded Decimal? @db.Decimal(5, 2)
  avgCopiesPlayed     Decimal? @db.Decimal(4, 2)
  replacementRate     Decimal? @db.Decimal(5, 2)

  // Computed PRI
  pri           Int?
  priConfidence Int?

  // Provenance
  format      String?
  windowStart DateTime?
  windowEnd   DateTime?

  lastSyncedAt DateTime @default(now())

  @@index([pri])
  @@index([deckInclusionPct])
}

// Per-sync snapshot of PRI. Lets the alert evaluator compare current PRI to
// a prior point in time (META_SHIFT detection). Append-only; no maintenance
// required beyond syncEngineMetrics writing one row per card per run.
model CardEngineMetricsHistory {
  id            String   @id @default(cuid())
  cardId        String
  card          Card     @relation(fields: [cardId], references: [id])
  pri           Int
  priConfidence Int?
  capturedAt    DateTime @default(now())

  @@index([cardId, capturedAt])
}

// =============================================================================
// Community Price Polls
// =============================================================================

model ValuePoll {
  id        String        @id @default(cuid())
  cardId    String
  card      Card          @relation(fields: [cardId], references: [id])
  treatment String
  condition CardCondition @default(NEAR_MINT)

  priceRanges Json
  status      PollStatus @default(ACTIVE)

  expiresAt DateTime
  createdAt DateTime @default(now())

  votes ValuePollVote[]
}

model ValuePollVote {
  id     String    @id @default(cuid())
  pollId String
  poll   ValuePoll @relation(fields: [pollId], references: [id])
  userId String
  user   User      @relation(fields: [userId], references: [id])

  selectedRange Int
  exactEstimate Decimal? @db.Decimal(10, 2)
  voterWeight   Float    @default(1.0)

  createdAt DateTime @default(now())

  @@unique([pollId, userId])
}

// =============================================================================
// Buylist
// =============================================================================

model Buylist {
  id       String  @id @default(cuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id])
  name     String
  isPublic Boolean @default(true)

  entries   BuylistEntry[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model BuylistEntry {
  id        String  @id @default(cuid())
  buylistId String
  buylist   Buylist @relation(fields: [buylistId], references: [id])
  cardId    String
  card      Card    @relation(fields: [cardId], references: [id])

  maxPrice  Decimal       @db.Decimal(10, 2)
  condition CardCondition @default(NEAR_MINT)
  treatment String
  quantity  Int           @default(1)

  autoNotify Boolean @default(true)

  @@unique([buylistId, cardId, treatment, condition])
}

// =============================================================================
// Manual Sale Reports
// =============================================================================

model SaleReport {
  id         String @id @default(cuid())
  reporterId String
  reporter   User   @relation(fields: [reporterId], references: [id])
  cardId     String
  card       Card   @relation(fields: [cardId], references: [id])

  price     Decimal       @db.Decimal(10, 2)
  condition CardCondition
  treatment String
  platform  String

  proofUrl   String?
  verified   Boolean @default(false)
  verifiedBy String?

  saleDate  DateTime
  createdAt DateTime @default(now())
}

// =============================================================================
// Marketplace — Listings
// =============================================================================

model Listing {
  id       String @id @default(cuid())
  sellerId String
  seller   User   @relation("SellerListings", fields: [sellerId], references: [id])

  type   ListingType
  cardId String?
  card   Card?       @relation(fields: [cardId], references: [id])

  condition    CardCondition?
  treatment    String?
  serialNumber String?

  // Pricing
  price        Decimal  @db.Decimal(10, 2)
  currency     String   @default("USD")
  allowOffers  Boolean  @default(true)
  minimumOffer Decimal? @db.Decimal(10, 2)

  // Stock
  quantity     Int @default(1)
  quantitySold Int @default(0)

  // Media
  photos String[]

  // Shipping
  shipsFrom       String?
  shippingOptions Json?

  status ListingStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  offers      Offer[]
  orders      Order[]
  mysteryPack MysteryPack?

  @@index([cardId, status])
  @@index([sellerId])
  @@index([type])
}

// =============================================================================
// Mystery Packs
// =============================================================================

model MysteryPack {
  id        String  @id @default(cuid())
  listingId String  @unique
  listing   Listing @relation(fields: [listingId], references: [id])

  name        String
  description String

  guaranteedMinValue Decimal @db.Decimal(10, 2)
  cardCount          Int

  tiers        Json
  revealPolicy RevealPolicy @default(BUYER_CHOICE)

  outcomes MysteryPackOutcome[]
}

model MysteryPackOutcome {
  id            String      @id @default(cuid())
  mysteryPackId String
  mysteryPack   MysteryPack @relation(fields: [mysteryPackId], references: [id])
  orderId       String

  contents   Json
  totalValue Decimal @db.Decimal(10, 2)

  buyerRating  Int?
  buyerComment String?

  createdAt DateTime @default(now())
}

// =============================================================================
// Offers & Negotiation
// =============================================================================

model Offer {
  id        String  @id @default(cuid())
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id])
  buyerId   String
  buyer     User    @relation(fields: [buyerId], references: [id])

  amount  Decimal @db.Decimal(10, 2)
  message String?

  status OfferStatus @default(PENDING)

  parentOfferId String?
  parentOffer   Offer?  @relation("OfferChain", fields: [parentOfferId], references: [id])
  counterOffers Offer[] @relation("OfferChain")

  order Order?

  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  respondedAt DateTime?
}

// =============================================================================
// Orders & Transactions
// =============================================================================

model Order {
  id        String  @id @default(cuid())
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id])
  buyerId   String
  buyer     User    @relation("BuyerOrders", fields: [buyerId], references: [id])
  sellerId  String
  seller    User    @relation("SellerOrders", fields: [sellerId], references: [id])

  // Financials
  quantity    Int     @default(1)
  subtotal    Decimal @db.Decimal(10, 2)
  shipping    Decimal @db.Decimal(10, 2)
  platformFee Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)

  // Stripe
  stripeCheckoutSessionId String? @unique
  stripePaymentIntentId   String?
  stripeTransferId        String?

  // Origin offer when this order was created from an accepted offer
  acceptedOfferId String? @unique
  acceptedOffer   Offer?  @relation(fields: [acceptedOfferId], references: [id])

  // Shipping
  shippingMethod  String
  trackingNumber  String?
  shippingAddress Json

  status OrderStatus @default(PENDING_PAYMENT)

  paidAt      DateTime?
  shippedAt   DateTime?
  deliveredAt DateTime?
  completedAt DateTime?

  buyerRating  Int?
  sellerRating Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =============================================================================
// Collection Tracking
// =============================================================================

model Collection {
  id       String  @id @default(cuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id])
  name     String  @default("My Collection")
  isPublic Boolean @default(false)

  cards CollectionCard[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CollectionCard {
  id           String     @id @default(cuid())
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id])
  cardId       String
  card         Card       @relation(fields: [cardId], references: [id])

  quantity     Int           @default(1)
  condition    CardCondition @default(NEAR_MINT)
  treatment    String
  serialNumber String?

  acquiredPrice Decimal?  @db.Decimal(10, 2)
  acquiredDate  DateTime?
  acquiredFrom  String?

  forTrade    Boolean  @default(false)
  forSale     Boolean  @default(false)
  askingPrice Decimal? @db.Decimal(10, 2)

  notes String?

  @@unique([collectionId, cardId, treatment, condition, serialNumber])
}

// =============================================================================
// Users & Reputation
// =============================================================================

model User {
  id          String  @id @default(cuid())
  email       String  @unique
  username    String  @unique
  displayName String?
  avatarUrl   String?
  bio         String?

  country String?
  region  String?

  role UserRole @default(USER)

  sellerRating   Float?   @default(0)
  buyerRating    Float?   @default(0)
  totalSales     Int      @default(0)
  totalPurchases Int      @default(0)
  memberSince    DateTime @default(now())

  isVerified               Boolean @default(false)
  stripeAccountId          String?
  // Cached snapshot of charges_enabled && payouts_enabled, updated by the
  // account.updated webhook. Avoids a per-request Stripe roundtrip when
  // gating "can this seller list a card" or "can this buyer pay".
  stripeOnboardingComplete Boolean @default(false)
  cardeioPlayerId          String?

  credibilityScore Float @default(1.0)

  // Relations
  collections    Collection[]
  buylists       Buylist[]
  sellerListings Listing[]       @relation("SellerListings")
  buyerOrders    Order[]         @relation("BuyerOrders")
  sellerOrders   Order[]         @relation("SellerOrders")
  offers         Offer[]
  pollVotes      ValuePollVote[]
  saleReports    SaleReport[]
  alerts         UserAlert[]
  proposedTrades Trade[]         @relation("TradeProposer")
  receivedTrades Trade[]         @relation("TradeRecipient")
}

// =============================================================================
// Alerts (PLANNING.md §9 — meta-shift / price-drop subscriptions)
// =============================================================================

model UserAlert {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  type   AlertType
  cardId String?
  card   Card?     @relation(fields: [cardId], references: [id])

  // For PRICE_DROP / PRICE_SPIKE: % change threshold that triggers the alert.
  // Null for BACK_IN_STOCK / META_SHIFT.
  thresholdPct Decimal? @db.Decimal(5, 2)

  active      Boolean   @default(true)
  lastFiredAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId, active])
  @@index([cardId, type])
}

// =============================================================================
// Trades (PLANNING.md §6 — card-for-card swaps)
// =============================================================================

model Trade {
  id          String @id @default(cuid())
  proposerId  String
  proposer    User   @relation("TradeProposer", fields: [proposerId], references: [id])
  recipientId String
  recipient   User   @relation("TradeRecipient", fields: [recipientId], references: [id])

  status TradeStatus @default(PROPOSED)

  // Optional cash equalizer paid by proposer to recipient (or negative for the
  // reverse direction). Null when the trade is a pure swap. Decimal(10,2) lets
  // the same money plumbing in checkout/webhook handle non-cash trades cleanly
  // when we later wire the payment leg.
  cashAdjustment Decimal? @db.Decimal(10, 2)

  message String?

  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  respondedAt DateTime?
  completedAt DateTime?

  items TradeItem[]

  @@index([proposerId])
  @@index([recipientId])
  @@index([status])
}

model TradeItem {
  id      String @id @default(cuid())
  tradeId String
  trade   Trade  @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  cardId  String
  card    Card   @relation(fields: [cardId], references: [id])

  // Which side this item belongs to. Trade items split into two groups by this
  // flag; both must net out to a fair (or cash-equalized) swap.
  fromProposer Boolean

  quantity  Int           @default(1)
  condition CardCondition @default(NEAR_MINT)
  treatment String

  @@index([tradeId])
}
